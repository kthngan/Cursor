# Get your API key from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_your_key_here

# Password you'll enter on your phone to access the agent
ACCESS_TOKEN=choose-a-long-random-password

# Folder the agent can read and edit
WORKSPACE_DIR=C:\Users\user\Documents\Cursor

# Local port (only exposed via tunnel)
PORT=8787
